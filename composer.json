{
    "name": "phpsoftbox/auth",
    "description": "Auth component for the PhpSoftBox framework",
    "type": "library",
    "config": {
        "sort-packages": true
    },
    "require": {
        "php": "^8.4",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/container": "^2.0",
        "phpsoftbox/session": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2",
        "phpsoftbox/http-message": "dev-master",
        "phpsoftbox/database": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "PhpSoftBox\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSoftBox\\Auth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs:fix": "vendor/bin/psb-cs-fixer fix",
        "cs:check": "vendor/bin/psb-cs-fixer check --diff"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
