{
    "name": "phpsoftbox/http-emitter",
    "description": "HTTP response emitter for the PhpSoftBox framework",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anton K.",
            "email": "inspector-who@mail.ru"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "require": {
        "php": "^8.4",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2",
        "phpsoftbox/http-message": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "PhpSoftBox\\Http\\Emitter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSoftBox\\Http\\Emitter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs:fix": "vendor/bin/psb-cs-fixer fix",
        "cs:check": "vendor/bin/psb-cs-fixer check --diff"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
